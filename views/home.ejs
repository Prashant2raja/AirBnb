<% layout("layouts/boilerplate") %>

<section class="home-hero">
  <div class="home-copy">
    <span class="home-badge">Airbnb-Inspired Demo</span>
    <h1>Discover beautiful stays with a clean, polished listing experience.</h1>
    <p>
      WandrLust is a full-stack project built to demonstrate listing management,
      elegant server-rendered pages, and a dependable MongoDB-backed CRUD flow.
    </p>
    <div class="home-actions">
      <a href="/listings" class="btn home-primary-btn">Explore Listings</a>
      <a href="/listings/new" class="btn home-secondary-btn">Create Listing</a>
    </div>
  </div>

  <div class="home-panel">
    <h2>What this project includes</h2>
    <ul class="home-feature-list">
      <li>Responsive listing pages built with EJS and Bootstrap</li>
      <li>MongoDB persistence with Mongoose models</li>
      <li>Full create, view, edit, and delete listing flows</li>
      <li>Reusable layout, navigation, footer, and validation helpers</li>
    </ul>
  </div>
</section>

<section class="home-section">
  <div class="section-head">
    <div>
      <span class="section-kicker">Project Highlights</span>
      <h2>Built to look organized in both code and UI</h2>
    </div>
    <a href="/listings" class="section-link">View all stays</a>
  </div>

  <div class="home-grid">
    <article class="home-card">
      <h3>Browse Listings</h3>
      <p>Explore cards with destination images, pricing, and direct detail pages.</p>
      <a href="/listings">Open listings</a>
    </article>

    <article class="home-card">
      <h3>Create New Stay</h3>
      <p>Add a new property with destination, pricing, image URL, and description.</p>
      <a href="/listings/new">Add a listing</a>
    </article>

    <article class="home-card">
      <h3>Professional Structure</h3>
      <p>Shared templates, utility helpers, seeded data, and readable routing for demos.</p>
      <a href="/privacy">See support pages</a>
    </article>
  </div>
</section>
