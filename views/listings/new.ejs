<% layout("layouts/boilerplate") %>

<section class="form-shell">
  <div class="form-header">
    <span class="section-kicker">Create</span>
    <h1>Add a new listing</h1>
    <p>Fill in the property details below to publish a new stay.</p>
  </div>

  <form method="POST" action="/listings" novalidate class="needs-validation listing-form">
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input
        name="listing[title]"
        placeholder="Enter listing title"
        type="text"
        class="form-control"
        required
      />
      <div class="invalid-feedback">Please enter a listing title.</div>
    </div>

    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
      <textarea
        name="listing[description]"
        placeholder="Describe the stay"
        class="form-control"
        rows="4"
        required
      ></textarea>
      <div class="invalid-feedback">Please enter a description.</div>
    </div>

    <div class="mb-3">
      <label for="image" class="form-label">Image URL</label>
      <input name="listing[image]" type="url" class="form-control" placeholder="https://example.com/photo.jpg" />
    </div>

    <div class="form-grid">
      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input
          name="listing[price]"
          class="form-control"
          placeholder="Enter nightly price"
          type="number"
          required
        />
        <div class="invalid-feedback">Please enter a valid price.</div>
      </div>

      <div class="mb-3">
        <label for="listing[country]" class="form-label">Country</label>
        <input
          name="listing[country]"
          placeholder="Enter country"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter a country.</div>
      </div>
    </div>

    <div class="mb-4">
      <label for="location" class="form-label">Location</label>
      <input
        name="listing[location]"
        placeholder="Enter city or destination"
        type="text"
        class="form-control"
        required
      />
      <div class="invalid-feedback">Please enter a location.</div>
    </div>

    <button class="btn home-primary-btn" type="submit">Publish Listing</button>
  </form>
</section>
