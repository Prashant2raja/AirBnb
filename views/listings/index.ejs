<% layout("layouts/boilerplate") %>

<section class="page-intro">
  <span class="section-kicker">All Stays</span>
  <h1>Explore curated travel listings</h1>
  <p>Browse hand-picked destinations, open details, or add your own listing to the collection.</p>
</section>

<section class="listing-grid">
  <% for (let listing of allListing) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <article class="listing-card">
        <img
          src="<%= listing.image.url %>"
          class="listing-image"
          alt="<%= listing.title %>"
        />
        <div class="listing-card-body">
          <div class="listing-card-top">
            <h2><%= listing.title %></h2>
            <span class="listing-price">&#8377;<%= listing.price.toLocaleString("en-IN") %> <small>/ night</small></span>
          </div>
          <p class="listing-meta"><%= listing.location %>, <%= listing.country %></p>
        </div>
      </article>
    </a>
  <% } %>
</section>
